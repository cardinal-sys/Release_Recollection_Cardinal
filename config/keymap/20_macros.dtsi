/* ============================================================
 * 20_macros.dtsi — マクロ定義
 *
 * macros { } の内側でインクルードされる。
 * ============================================================ */

safari_reload_once: safari_reload_once {
    compatible = "zmk,behavior-macro";
    label = "SAFARI_RELOAD_ONCE";
    #binding-cells = <0>;
    bindings =
        <&macro_press>,
        <&kp LGUI>,
        <&macro_tap>,
        <&kp R>,
        <&macro_release>,
        <&kp LGUI>;
};

to_layer_0: to_layer_0 {
    compatible = "zmk,behavior-macro-one-param";
    label = "TO_LAYER_0";
    #binding-cells = <1>;
    bindings = <&to 0 &macro_param_1to1 &kp MACRO_PLACEHOLDER>;
};

drag_on: drag_on {
    compatible = "zmk,behavior-macro";
    label = "DRAG_ON";
    #binding-cells = <0>;
    bindings = <&macro_press>, <&mkp MB1>;
};

drag_off: drag_off {
    compatible = "zmk,behavior-macro";
    label = "DRAG_OFF";
    #binding-cells = <0>;
    bindings = <&macro_release>, <&mkp MB1>;
};

lm: lm {
    compatible = "zmk,behavior-macro-two-param";
    #binding-cells = <2>;
    wait-ms = <0>;
    tap-ms = <0>;
    bindings =
        <&macro_param_1to1>,
        <&macro_press>,
        <&mo MACRO_PLACEHOLDER &macro_param_2to1>,
        <&macro_press>,
        <&kp MACRO_PLACEHOLDER>,
        <&macro_pause_for_release>,
        <&macro_param_2to1>,
        <&macro_release>,
        <&kp MACRO_PLACEHOLDER &macro_param_1to1>,
        <&macro_release>,
        <&mo MACRO_PLACEHOLDER>;
};

/* ============================================================
 * 〈Phantom Connection Banishment〉— BT Solo Sigils
 *
 * BT_SEL でアクティブ profile を選択した直後に、他 4 profile への
 * 接続を BT_DISC で能動的に切断する。ZMK 既定では非アクティブ profile
 * とも BLE 接続が維持されるため、複数ホスト同時接続時に BLE 帯域が
 * 奪い合いとなりカーソル遅延（特にトラックボール）が発生する。
 * 各ホスト側は paired 状態が残っているため、後で BT_SEL すれば自動
 * 再接続される。
 * BT_MAX_CONN=6 (プロファイル数 5 + スプリット相方 1) を前提。
 * ============================================================ */

bt_solo_0: bt_solo_0 {
    compatible = "zmk,behavior-macro";
    label = "BT_SOLO_0";
    #binding-cells = <0>;
    bindings = <&bt BT_SEL 0>,
               <&bt BT_DISC 1>,
               <&bt BT_DISC 2>,
               <&bt BT_DISC 3>,
               <&bt BT_DISC 4>;
};

bt_solo_1: bt_solo_1 {
    compatible = "zmk,behavior-macro";
    label = "BT_SOLO_1";
    #binding-cells = <0>;
    bindings = <&bt BT_SEL 1>,
               <&bt BT_DISC 0>,
               <&bt BT_DISC 2>,
               <&bt BT_DISC 3>,
               <&bt BT_DISC 4>;
};

bt_solo_2: bt_solo_2 {
    compatible = "zmk,behavior-macro";
    label = "BT_SOLO_2";
    #binding-cells = <0>;
    bindings = <&bt BT_SEL 2>,
               <&bt BT_DISC 0>,
               <&bt BT_DISC 1>,
               <&bt BT_DISC 3>,
               <&bt BT_DISC 4>;
};

bt_solo_3: bt_solo_3 {
    compatible = "zmk,behavior-macro";
    label = "BT_SOLO_3";
    #binding-cells = <0>;
    bindings = <&bt BT_SEL 3>,
               <&bt BT_DISC 0>,
               <&bt BT_DISC 1>,
               <&bt BT_DISC 2>,
               <&bt BT_DISC 4>;
};

bt_solo_4: bt_solo_4 {
    compatible = "zmk,behavior-macro";
    label = "BT_SOLO_4";
    #binding-cells = <0>;
    bindings = <&bt BT_SEL 4>,
               <&bt BT_DISC 0>,
               <&bt BT_DISC 1>,
               <&bt BT_DISC 2>,
               <&bt BT_DISC 3>;
};
