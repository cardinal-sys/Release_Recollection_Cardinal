/* ============================================================
 * 20_macros.dtsi — マクロ定義
 *
 * macros { } の内側でインクルードされる。
 * ============================================================ */

safari_reload_once: safari_reload_once {
    compatible = "zmk,behavior-macro";
    label = "SAFARI_RELOAD_ONCE";
    #binding-cells = <0>;
    bindings =
        <&macro_press>,
        <&kp LGUI>,
        <&macro_tap>,
        <&kp R>,
        <&macro_release>,
        <&kp LGUI>;
};

to_layer_0: to_layer_0 {
    compatible = "zmk,behavior-macro-one-param";
    label = "TO_LAYER_0";
    #binding-cells = <1>;
    bindings = <&to 0 &macro_param_1to1 &kp MACRO_PLACEHOLDER>;
};

drag_on: drag_on {
    compatible = "zmk,behavior-macro";
    label = "DRAG_ON";
    #binding-cells = <0>;
    bindings = <&macro_press>, <&mkp MB1>;
};

drag_off: drag_off {
    compatible = "zmk,behavior-macro";
    label = "DRAG_OFF";
    #binding-cells = <0>;
    bindings = <&macro_release>, <&mkp MB1>;
};

lm: lm {
    compatible = "zmk,behavior-macro-two-param";
    #binding-cells = <2>;
    wait-ms = <0>;
    tap-ms = <0>;
    bindings =
        <&macro_param_1to1>,
        <&macro_press>,
        <&mo MACRO_PLACEHOLDER &macro_param_2to1>,
        <&macro_press>,
        <&kp MACRO_PLACEHOLDER>,
        <&macro_pause_for_release>,
        <&macro_param_2to1>,
        <&macro_release>,
        <&kp MACRO_PLACEHOLDER &macro_param_1to1>,
        <&macro_release>,
        <&mo MACRO_PLACEHOLDER>;
};

/* ============================================================
 * 〈BT Solo Sigils · Pure Switch〉— BT プロファイル切替
 *
 * 各 bt_solo_N は純粋な &bt BT_SEL N（プロファイル切替のみ）。
 * 旧版〈Phantom Connection Banishment〉では BT_SEL 直後に他 4 profile への
 * BT_DISC を連射し非アクティブ profile を強制切断していたが、
 *   (1) 切替のたびに他の接続中ホストまで切断する副作用、
 *   (2) ペアリング進行中に押すと新規 bond 確立を破壊し「2台目以降ペア不可」
 *       を招く副作用、
 * が大きいため BT_DISC 連射を撤去し純切替へ収束させた。
 * これにより bt_solo_N と bt_pair_N は等価（共に純 BT_SEL）。
 * 複数ホスト同時接続の BLE 帯域奪い合い（トラックボール遅延）が再発する場合は
 * 不要 profile を &bt BT_DISC で個別に切断する運用で対処する。
 * ============================================================ */

bt_solo_0: bt_solo_0 {
    compatible = "zmk,behavior-macro";
    label = "BT_SOLO_0";
    #binding-cells = <0>;
    bindings = <&bt BT_SEL 0>;
};

bt_solo_1: bt_solo_1 {
    compatible = "zmk,behavior-macro";
    label = "BT_SOLO_1";
    #binding-cells = <0>;
    bindings = <&bt BT_SEL 1>;
};

bt_solo_2: bt_solo_2 {
    compatible = "zmk,behavior-macro";
    label = "BT_SOLO_2";
    #binding-cells = <0>;
    bindings = <&bt BT_SEL 2>;
};

bt_solo_3: bt_solo_3 {
    compatible = "zmk,behavior-macro";
    label = "BT_SOLO_3";
    #binding-cells = <0>;
    bindings = <&bt BT_SEL 3>;
};

bt_solo_4: bt_solo_4 {
    compatible = "zmk,behavior-macro";
    label = "BT_SOLO_4";
    #binding-cells = <0>;
    bindings = <&bt BT_SEL 4>;
};

/* ============================================================
 * 〈Pure Pairing Sigils〉— BT Pair Sigils
 *
 * 純粋な `&bt BT_SEL N` のみを発火するペアリング sigil。
 * 〈BT Solo Sigils · Pure Switch〉化により bt_solo_N も今は純 BT_SEL となり、
 * bt_pair_N と等価。新規ペアリング・日常切替のどちらにも使用可。
 * （履歴: 旧 bt_solo は BT_DISC 連射で新規 bond を破壊していたため、
 *  当時は純 BT_SEL の bt_pair を別建てして回避していた。現在は両者統一。）
 * ============================================================ */

bt_pair_0: bt_pair_0 {
    compatible = "zmk,behavior-macro";
    label = "BT_PAIR_0";
    #binding-cells = <0>;
    bindings = <&bt BT_SEL 0>;
};

bt_pair_1: bt_pair_1 {
    compatible = "zmk,behavior-macro";
    label = "BT_PAIR_1";
    #binding-cells = <0>;
    bindings = <&bt BT_SEL 1>;
};

bt_pair_2: bt_pair_2 {
    compatible = "zmk,behavior-macro";
    label = "BT_PAIR_2";
    #binding-cells = <0>;
    bindings = <&bt BT_SEL 2>;
};

bt_pair_3: bt_pair_3 {
    compatible = "zmk,behavior-macro";
    label = "BT_PAIR_3";
    #binding-cells = <0>;
    bindings = <&bt BT_SEL 3>;
};

bt_pair_4: bt_pair_4 {
    compatible = "zmk,behavior-macro";
    label = "BT_PAIR_4";
    #binding-cells = <0>;
    bindings = <&bt BT_SEL 4>;
};
