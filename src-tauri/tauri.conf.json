{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cardinal Editor",
  "version": "0.1.0",
  "identifier": "com.administ-rator.cardinal-editor",
  "build": {
    "frontendDist": "../editor",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "python3 scripts/cardinal_editor_server.py",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "《 CARDINAL EDITOR 》",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Cardinal Editor — ZMK keymap editor with Live Sync",
    "longDescription": "Cardinal Editor は Release Recollection キーボードのキーマップを編纂する Web/デスクトップアプリ。git 経由のソース編集 + ZMK Studio 経由のライブ書換を統合。Tauri 版は OS ネイティブ Bluetooth API により macOS HID 接続中でも BLE Live Sync が利用可能。",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": null
    }
  },
  "plugins": {}
}
